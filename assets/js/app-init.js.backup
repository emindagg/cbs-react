/**
 * App Initialization - MapLibre GL JS
 * Core application setup: map, sources, layers, UI panels, and global state
 */

// ==========================================
// GLOBAL STATE VARIABLES
// ==========================================
window.userMarkers = []; // Kullanıcının eklediği verileri saklamak için dizi
window.measurements = []; // Ölçüm sonuçları
window.isDrawing = false;
window.currentTool = null;

// Buffer toggle durumu
window.bufferActive = false;
window.lastBufferRadius = null;

// Analiz araçları durum takibi
window.analysisStates = {
    convex: false,
    voronoi: false,
    nearest: false
};

// Katalog geometri katmanları (polygon/line/circle) için referans listesi
window.catalogGeometryLayers = [];

// MapLibre GL JS specific: Track markers and layers
window.mapMarkers = []; // Array to store maplibregl.Marker instances
window.clusteringEnabled = false;

// ==========================================
// UI PANEL CONTROLS
// ==========================================
(function() {
    const sidebar = document.getElementById('sidebar');
    const openSidebar = document.getElementById('open-sidebar');
    const toolsPanel = document.getElementById('tools-panel');
    const openTools = document.getElementById('open-tools');
    const mapMain = document.getElementById('map-main');
    const mapControls = document.getElementById('map-control-container');
    
    const toggleBasemapBtn = document.getElementById('toggle-basemap-button');
    const basemapPanel = document.getElementById('basemap-panel');
    const toggleAstroBtn = document.getElementById('toggle-astro-button');
    const astroPanel = document.getElementById('astro-panel');

    const SIDEBAR_STATE_KEY = 'ui.sidebar.open';
    const TOOLS_STATE_KEY = 'ui.tools.open';

    function positionControls(){
        if (!mapControls) return;
        
        const sidebarVisible = sidebar && !isElementHidden(sidebar);
        const isMdUp = window.matchMedia('(min-width: 768px)').matches;
        
        const coordinateDisplay = document.getElementById('coordinate-display');
        const scaleLineContainer = document.getElementById('scale-line-container');
        const labelFab = document.getElementById('label-fab');
        
        // Sidebar genişliğini hesapla (kapalıyken 0, açıkken gerçek genişlik)
        let sidebarWidth = 0;
        if (sidebar) {
            if (sidebarVisible && isMdUp) {
                sidebarWidth = sidebar.offsetWidth || 288; // Varsayılan genişlik
            } else {
                sidebarWidth = 0; // Kapalıyken genişlik 0
            }
        }
        
        // Sidebar kapalıyken kontrolleri 0.6rem (9.6px) konumuna koy, açıkken sidebar'ın sağına
        const spacing = sidebarWidth > 0 ? 16 : 9.6; // Sidebar açıkken 16px, kapalıyken 0.6rem
        mapControls.style.left = `${sidebarWidth + spacing}px`;
        
        if (basemapPanel) {
            basemapPanel.style.left = `${sidebarWidth + spacing}px`;
            basemapPanel.style.top = '12.5rem';
        }
        
        if (astroPanel) {
            astroPanel.style.left = `${sidebarWidth + spacing}px`;
            astroPanel.style.top = '20rem';
        }
        
        if (coordinateDisplay) {
            coordinateDisplay.style.left = `${sidebarWidth + spacing}px`;
        }
        
        if (labelFab) {
            labelFab.style.left = `${sidebarWidth + spacing}px`;
        }
    }

    window.positionControls = positionControls;

    function openSidebarPanel(){
        if (!sidebar) return;
        sidebar.classList.remove('hidden');
        sidebar.style.display = 'flex';
        openSidebar && openSidebar.setAttribute('aria-expanded', 'true');
        positionControls();
        setTimeout(() => {
            if (window.map && typeof window.map.resize === 'function') {
                window.map.resize();
            }
        }, 100);
    }
    
    function closeSidebarPanel(){
        if (!sidebar) return;
        sidebar.classList.add('hidden');
        sidebar.style.display = 'none';
        openSidebar && openSidebar.setAttribute('aria-expanded', 'false');
        positionControls();
        setTimeout(() => {
            if (window.map && typeof window.map.resize === 'function') {
                window.map.resize();
            }
        }, 100);
    }

    function openToolsPanel(){
        if (!toolsPanel) return;
        toolsPanel.classList.remove('hidden');
        toolsPanel.style.display = 'block';
        openTools && openTools.setAttribute('aria-expanded', 'true');
    }
    
    function closeToolsPanel(){
        if (!toolsPanel) return;
        toolsPanel.classList.add('hidden');
        toolsPanel.style.display = 'none';
        openTools && openTools.setAttribute('aria-expanded', 'false');
    }

    openSidebar && openSidebar.addEventListener('click', function(){
        if (isElementHidden(sidebar)) { 
            openSidebarPanel(); 
            setStorageItem(SIDEBAR_STATE_KEY, '1'); 
        } else { 
            closeSidebarPanel(); 
            setStorageItem(SIDEBAR_STATE_KEY, '0'); 
        }
    });
    
    try {
        const sidebarState = getStorageItem(SIDEBAR_STATE_KEY);
        if (sidebarState === '1') { openSidebarPanel(); }
        if (sidebarState === '0') { closeSidebarPanel(); }
        
        // İlk yüklemede kontrolleri konumlandır
        positionControls();
        
        const toolsState = getStorageItem(TOOLS_STATE_KEY);
        if (toolsState === '1') { 
            openToolsPanel(); 
        } else if (toolsState === '0') { 
            closeToolsPanel(); 
        } else {
            // Default behavior: show tools panel on desktop, hide on mobile
            const isMdUp = window.matchMedia('(min-width: 768px)').matches;
            if (isMdUp) {
                openToolsPanel();
            } else {
                closeToolsPanel();
            }
        }
        // Sidebar render edildikten sonra kontrolleri konumlandır
        setTimeout(() => {
            positionControls();
        }, 100);
    } catch (e) {
        // localStorage erişimine izin yoksa sessiz geç
        // Yine de kontrolleri konumlandırmayı dene
        setTimeout(() => {
            positionControls();
        }, 100);
    }

    openTools && openTools.addEventListener('click', function(){
        if (isElementHidden(toolsPanel)) { 
            openToolsPanel(); 
            setStorageItem(TOOLS_STATE_KEY, '1'); 
        } else { 
            closeToolsPanel(); 
            setStorageItem(TOOLS_STATE_KEY, '0'); 
        }
    });

    setTimeout(positionControls, 50);

    // Altlık Harita Paneli
    if (toggleBasemapBtn && basemapPanel) {
        toggleBasemapBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            
            if (basemapPanel.classList.contains('hidden')) {
                const fabMenu = document.getElementById('fab-menu');
                if (fabMenu) {
                    fabMenu.style.display = 'none';
                }
            }
            
            basemapPanel.classList.toggle('hidden');
        });
        
        document.addEventListener('click', (e) => {
            if (!basemapPanel.classList.contains('hidden') && 
                !basemapPanel.contains(e.target) && 
                e.target !== toggleBasemapBtn && 
                !toggleBasemapBtn.contains(e.target)) {
                 basemapPanel.classList.add('hidden');
            }
        });
    }
    
    // Astronomi Paneli (astro-globe.js'de de kontrol ediliyor, burada sadece pozisyonlama)
    if (toggleAstroBtn && astroPanel) {
        toggleAstroBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            
            if (astroPanel.classList.contains('hidden')) {
                const fabMenu = document.getElementById('fab-menu');
                const basemapPanel = document.getElementById('basemap-panel');
                if (fabMenu) fabMenu.style.display = 'none';
                if (basemapPanel) basemapPanel.classList.add('hidden');
            }
        });
    }
})();

// ==========================================
// MAP INITIALIZATION - MapLibre GL JS
// ==========================================

// Initialize map using map-config.js
const { map, config } = initializeMap('map');
window.map = map;
window.MapConfig = config;

// Globe görünümünü style yüklendiğinde hazırla
map.on('style.load', () => {
    // Globe projection destekleniyorsa hazırla
    if (typeof map.setProjection === 'function') {
        
    }
});

// Custom zoom butonlarını bağla
const zoomInButton = document.getElementById('zoom-in-button');
const zoomOutButton = document.getElementById('zoom-out-button');
if (zoomInButton) {
    zoomInButton.addEventListener('click', function () {
        window.map.zoomIn();
    });
}
if (zoomOutButton) {
    zoomOutButton.addEventListener('click', function () {
        window.map.zoomOut();
    });
}

// ==========================================
// DATA SOURCES INITIALIZATION
// ==========================================
// MapLibre uses sources and layers instead of LayerGroups
window.dataSources = {
    markers: {
        type: 'geojson',
        data: {
            type: 'FeatureCollection',
            features: []
        },
        cluster: false // Will be enabled when clustering is activated
    },
    catalogGeometries: {
        type: 'geojson',
        data: {
            type: 'FeatureCollection',
            features: []
        }
    },
    measurements: {
        type: 'geojson',
        data: {
            type: 'FeatureCollection',
            features: []
        }
    },
    buffers: {
        type: 'geojson',
        data: {
            type: 'FeatureCollection',
            features: []
        }
    },
    convexHull: {
        type: 'geojson',
        data: {
            type: 'FeatureCollection',
            features: []
        }
    },
    voronoi: {
        type: 'geojson',
        data: {
            type: 'FeatureCollection',
            features: []
        }
    },
    nearestFacility: {
        type: 'geojson',
        data: {
            type: 'FeatureCollection',
            features: []
        }
    },
    heatmap: {
        type: 'geojson',
        data: {
            type: 'FeatureCollection',
            features: []
        }
    }
};

// Initialize sources and layers when map is loaded
window.map.on('load', () => {
    
    // Add catalog geometries source and layers
    window.map.addSource('catalog-geometries', window.dataSources.catalogGeometries);
    
    // İlk symbol layer'ı bul (catalog layer'ları symbol'ün altına eklemek için)
    const layers = window.map.getStyle().layers;
    const firstSymbolLayer = layers.find(l => l.type === 'symbol');
    const beforeId = firstSymbolLayer ? firstSymbolLayer.id : undefined;
    
    // Polygon fill layer
    window.map.addLayer({
        id: 'catalog-polygons',
        type: 'fill',
        source: 'catalog-geometries',
        filter: ['==', ['geometry-type'], 'Polygon'],
        paint: {
            'fill-color': ['get', 'fillColor'],
            'fill-opacity': ['coalesce', ['get', 'fillOpacity'], 0.3]
        }
    }, beforeId);
    
    // Polygon outline layer (solid lines - for circles)
    window.map.addLayer({
        id: 'catalog-polygon-outlines',
        type: 'line',
        source: 'catalog-geometries',
        filter: ['==', ['geometry-type'], 'Polygon'],
        paint: {
            'line-color': ['get', 'strokeColor'],
            'line-width': ['coalesce', ['get', 'strokeWidth'], 2]
        }
    }, beforeId);
    
    // Polygon outline layer (dashed - for circles with dashArray property)
    window.map.addLayer({
        id: 'catalog-polygon-outlines-dashed',
        type: 'line',
        source: 'catalog-geometries',
        filter: ['all',
            ['==', ['geometry-type'], 'Polygon'],
            ['==', ['get', 'type'], 'circle']
        ],
        paint: {
            'line-color': ['get', 'strokeColor'],
            'line-width': ['coalesce', ['get', 'strokeWidth'], 2],
            'line-dasharray': [6, 4] // Sabit kesikli çizgi
        }
    }, beforeId);
    
    // LineString layer
    window.map.addLayer({
        id: 'catalog-lines',
        type: 'line',
        source: 'catalog-geometries',
        filter: ['==', ['geometry-type'], 'LineString'],
        paint: {
            'line-color': ['get', 'strokeColor'],
            'line-width': 2
        }
    }, beforeId);
    
    // Add measurements source and layers
    window.map.addSource('measurements', window.dataSources.measurements);
    
    // Measurement lines
    window.map.addLayer({
        id: 'measurement-lines',
        type: 'line',
        source: 'measurements',
        filter: ['==', ['geometry-type'], 'LineString'],
        paint: {
            'line-color': '#ff0000',
            'line-width': 3,
            'line-dasharray': [2, 2]
        }
    });
    
    // Measurement polygons
    window.map.addLayer({
        id: 'measurement-polygons',
        type: 'fill',
        source: 'measurements',
        filter: ['==', ['geometry-type'], 'Polygon'],
        paint: {
            'fill-color': '#22c55e',
            'fill-opacity': 0.3
        }
    });
    
    window.map.addLayer({
        id: 'measurement-polygon-outlines',
        type: 'line',
        source: 'measurements',
        filter: ['==', ['geometry-type'], 'Polygon'],
        paint: {
            'line-color': '#22c55e',
            'line-width': 2
        }
    });
    
    // Add buffer source and layers
    window.map.addSource('buffers', window.dataSources.buffers);
    
    window.map.addLayer({
        id: 'buffer-fills',
        type: 'fill',
        source: 'buffers',
        paint: {
            'fill-color': '#9333ea',
            'fill-opacity': 0.3
        }
    });
    
    window.map.addLayer({
        id: 'buffer-outlines',
        type: 'line',
        source: 'buffers',
        paint: {
            'line-color': '#9333ea',
            'line-width': 2
        }
    });
});

// ==========================================
// MOUSE COORDINATES AND SCALE
// ==========================================
// NOTE: Mouse coordinates and scale display are handled by ui-components.js
// This prevents duplicate event listener registrations
// See: UIComponents.initializeScaleDisplay()

// ==========================================
// MAP CLICK ORCHESTRATOR INITIALIZATION
// ==========================================
// Initialize the centralized map click handler to prevent duplicate listeners
if (typeof MapClickOrchestrator !== 'undefined') {
    window.mapClickOrchestrator = new MapClickOrchestrator(window.map);
    window.mapClickOrchestrator.initialize();
} else {
    console.warn('MapClickOrchestrator not available - map clicks may have conflicts');
}

// ==========================================
// Initialize Timeline Manager
// ==========================================
if (typeof initializeTimeline !== 'undefined') {
    initializeTimeline(window.map);
} else {
    console.warn('Timeline Manager not available');
}

// ==========================================
// Initialize Astronomy Globe Module
// ==========================================
// AstroGlobe modülü script yüklendikten sonra initialize edilir
// map load event'ini beklemek yerine, modül hazır olduğunda kontrol et
function initializeAstroGlobe() {
    if (typeof window.AstroGlobe !== 'undefined' && window.map) {
        if (window.map.isStyleLoaded()) {
            window.AstroGlobe.initialize(window.map);
        } else {
            window.map.once('style.load', () => {
                window.AstroGlobe.initialize(window.map);
            });
        }
    } else {
        // Modül henüz yüklenmemiş, kısa bir süre sonra tekrar dene
        setTimeout(initializeAstroGlobe, 100);
    }
}

// DOMContentLoaded sonrası başlat
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
        setTimeout(initializeAstroGlobe, 500);
    });
} else {
    setTimeout(initializeAstroGlobe, 500);
}
